# Rename this file to .env and fill in your keys.
# The app reads these at startup via python-dotenv.

# Google Places API key (required for nearby store search)
# Get one free at: https://console.cloud.google.com -> APIs -> Places API
GOOGLE_PLACES_API_KEY=your_key_here

# How far to search for stores (meters). 8000m ≈ 5 miles.
STORE_SEARCH_RADIUS_METERS=8000

# Kroger Developer API (covers Fred Meyer + QFC — required for Kroger availability)
# Sign up free at: https://developer.kroger.com/ -> My Apps -> Create App
# Scope needed: product.compact
KROGER_CLIENT_ID=your_client_id_here
KROGER_CLIENT_SECRET=your_client_secret_here
